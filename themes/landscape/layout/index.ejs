<%
var posts = page.posts;
function slugifyLabel(value) {
  return String(value || 'uncategorized').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'uncategorized';
}
function categoryItems(post) {
  var items = [];
  if (post.categories && post.categories.data && post.categories.data.length) {
    post.categories.data.forEach(function(category) {
      items.push({
        name: category.name,
        slug: category.slug || slugifyLabel(category.name)
      });
    });
  }
  if (!items.length) {
    items.push({ name: 'Uncategorized', slug: 'uncategorized' });
  }
  return items;
}
var filters = [{ label: 'All', slug: 'all' }];
var seenFilters = { all: true };
posts.each(function(post) {
  categoryItems(post).forEach(function(category) {
    if (!seenFilters[category.slug]) {
      seenFilters[category.slug] = true;
      filters.push({ label: category.name, slug: category.slug });
    }
  });
});
var featuredPost = posts.length ? posts.data[0] : null;
var secondaryPost = posts.length > 1 ? posts.data[1] : featuredPost;
function coverName(post) {
  return post.cover || 'editorial-grid';
}
%>

<section class="masthead">
  <div class="masthead__title">
    <p class="eyebrow">chen's notebook / personal dispatches</p>
    <h1>chen's blog</h1>
  </div>
  <div class="masthead__copy">
    <p class="lede">Notes on &#35774;&#35745;, &#24320;&#21457;, observations, and unfinished ideas, arranged like an editorial index instead of a default blog splash.</p>
    <p class="subcopy">A quieter front page with mixed language rhythm, image-like cover blocks, and a scrolling reading index.</p>
  </div>
</section>

<section class="cover-grid">
  <article class="cover-card cover-card--intro">
    <p class="cover-card__kicker">Editorial Note</p>
    <h2>Less hero, more mood.</h2>
    <p>The opening screen avoids a giant hero and moves closer to a portfolio cover and an independent magazine front page, with a touch of &#20013;&#33521;&#28151;&#25490;.</p>
  </article>

  <article class="cover-card cover-card--featured">
    <p class="cover-card__kicker">Latest Cover</p>
    <% if (featuredPost) { %>
      <div class="cover-art cover-art--<%= coverName(featuredPost) %>"></div>
      <h2><a href="<%= url_for(featuredPost.path) %>"><%= featuredPost.title %></a></h2>
      <p><%= truncate(strip_html(featuredPost.excerpt || featuredPost.content || ''), {length: 120}) %></p>
      <div class="cover-card__meta">
        <time datetime="<%= date_xml(featuredPost.date) %>"><%= date(featuredPost.date, 'YYYY.MM.DD') %></time>
        <span><%= categoryItems(featuredPost)[0].name %></span>
      </div>
    <% } else { %>
      <h2>Awaiting first entry</h2>
      <p>Publish your first post and this area will automatically become the live cover of the site.</p>
    <% } %>
  </article>

  <article class="cover-card cover-card--stack">
    <p class="cover-card__kicker">Site Frame</p>
    <div class="mini-stack">
      <div>
        <span class="mini-stack__label">Archive begins</span>
        <strong><%= site.posts.length ? date(site.posts.first().date, 'YYYY') : 'Now' %></strong>
      </div>
      <div>
        <span class="mini-stack__label">Entries</span>
        <strong><%= site.posts.length %></strong>
      </div>
      <div>
        <span class="mini-stack__label">Next read</span>
        <strong><%= secondaryPost ? secondaryPost.title : 'Coming soon' %></strong>
      </div>
    </div>
  </article>
</section>

<section class="split-section" id="posts">
  <aside class="split-section__sidebar">
    <div class="sticky-panel">
      <p class="eyebrow">Scroll index</p>
      <h2>Selected writing / &#20998;&#31867;&#31679;&#36873;</h2>
      <p class="sticky-panel__copy">The left rail stays pinned while the right side keeps moving. Filter the list in place and keep the reading flow uninterrupted.</p>
      <div class="filter-row" aria-label="Category filters">
        <% filters.forEach(function(filter) { %>
          <button class="filter-chip<%= filter.slug === 'all' ? ' is-active' : '' %>" type="button" data-filter="<%= filter.slug %>"><%= filter.label %></button>
        <% }) %>
      </div>
      <a class="button button--ghost" href="<%= url_for('/archives/') %>">Browse archive</a>
    </div>
  </aside>

  <div class="split-section__content">
    <% posts.each(function(post, index) { 
      var categories = categoryItems(post);
      var categorySlugs = categories.map(function(category) { return category.slug; }).join(' ');
    %>
      <article class="post-panel" data-categories="<%= categorySlugs %>">
        <div class="post-panel__topline">
          <span><%= String(index + 1).padStart(2, '0') %></span>
          <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY.MM.DD') %></time>
        </div>
        <div class="post-panel__body">
          <div class="post-panel__cover cover-art cover-art--<%= coverName(post) %>"></div>
          <div class="post-panel__header">
            <h3><a href="<%= url_for(post.path) %>"><%= post.title %></a></h3>
            <div class="post-panel__tags">
              <% categories.forEach(function(category) { %>
                <span><%= category.name %></span>
              <% }) %>
            </div>
          </div>
          <p><%= truncate(strip_html(post.excerpt || post.content || ''), {length: 180}) %></p>
          <a class="post-card__link" href="<%= url_for(post.path) %>">Open article</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>
